{
  "name": "vibeable",
  "private": true,
  "description": "Self-hosted, policy-aware AI application builder for teams",
  "license": "SEE LICENSE IN LICENSE",
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "concurrently -k -n api,web -c yellow,cyan \"pnpm dev:api\" \"pnpm dev:web\"",
    "dev:api": "tsx watch server/index.ts",
    "dev:web": "vite --host 127.0.0.1",
    "build": "pnpm typecheck && vite build && pnpm build:server",
    "build:server": "node scripts/clean-server-build.mjs && tsc -p tsconfig.server.build.json",
    "start": "node dist-server/server/index.js",
    "preview": "vite preview --host 127.0.0.1",
    "typecheck": "tsc -p tsconfig.web.json --noEmit && tsc -p tsconfig.server.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "licenses:generate": "node scripts/generate-third-party-notices.mjs",
    "licenses:check": "node scripts/generate-third-party-notices.mjs --check",
    "db:migrate": "tsx server/scripts/migrate.ts",
    "db:bootstrap": "tsx server/scripts/bootstrap.ts",
    "check": "pnpm licenses:check && pnpm typecheck && pnpm test && pnpm build"
  },
  "dependencies": {
    "@fastify/cookie": "^11.1.2",
    "@fastify/cors": "^11.3.0",
    "@fastify/helmet": "^13.1.0",
    "@fastify/rate-limit": "^11.1.0",
    "@fastify/static": "^10.1.0",
    "bcryptjs": "^3.0.3",
    "fastify": "^5.10.0",
    "jose": "^6.2.3",
    "lucide-react": "^0.468.0",
    "pg": "^8.22.0",
    "pino": "^10.3.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "undici": "^7.28.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "^10.0.3",
    "embedded-postgres": "18.4.0-beta.17",
    "tsx": "^4.23.1",
    "typescript": "^5.8.0",
    "vite": "^7.0.0",
    "vitest": "^4.1.10"
  }
}
