POSTGRES_PASSWORD=replace-with-a-long-random-database-password
MASTER_KEY=replace-with-at-least-32-random-bytes
PUBLIC_URL=http://localhost:8787
COOKIE_SECURE=false
LOCAL_LOGIN_ENABLED=true
OIDC_ENABLED=false
OIDC_ISSUER=https://idp.example.com/application/o/vibeable
OIDC_CLIENT_ID=vibeable
OIDC_CLIENT_SECRET=replace-with-oidc-client-secret
OIDC_ORGANIZATION_SLUG=your-organization-slug
OIDC_AUTO_PROVISION=false
OIDC_ALLOW_EMAIL_LINKING=false
OIDC_ROLE_MAPPING={"vibeable-developers":"developer"}
OIDC_TEAM_MAPPING={"platform-team":"platform"}
VIBEABLE_PORT=8787
REQUIRE_SEPARATE_APPROVER=true
TRUST_PROXY=false
EXECUTION_MODE=disabled
DEPLOYMENT_EXECUTION_MODE=disabled
ALLOW_PRIVATE_AI_ENDPOINTS=false
