NODE_ENV=development
HOST=127.0.0.1
PORT=8787
PUBLIC_URL=http://127.0.0.1:5173
DATABASE_URL=postgres://vibeable:vibeable@127.0.0.1:5432/vibeable
DATABASE_SSL=disable
MASTER_KEY=replace-with-at-least-32-random-bytes
SESSION_TTL_DAYS=14
LOCAL_LOGIN_ENABLED=true
OIDC_ENABLED=false
OIDC_ISSUER=https://idp.example.com/application/o/vibeable
OIDC_CLIENT_ID=vibeable
OIDC_CLIENT_SECRET=replace-with-oidc-client-secret
OIDC_CLIENT_AUTH_METHOD=client_secret_basic
OIDC_DISPLAY_NAME=Company SSO
OIDC_SCOPES=openid profile email groups
OIDC_ORGANIZATION_SLUG=your-organization-slug
OIDC_AUTO_PROVISION=false
OIDC_ALLOW_EMAIL_LINKING=false
OIDC_DEFAULT_ROLE=viewer
OIDC_SIGNING_ALGORITHMS=RS256,ES256
OIDC_GROUPS_CLAIM=groups
OIDC_ROLE_MAPPING={"vibeable-admins":"admin","vibeable-developers":"developer","vibeable-reviewers":"reviewer"}
OIDC_TEAM_MAPPING={"platform-team":"platform","product-team":"product"}
OIDC_SYNC_TEAM_MEMBERSHIPS=true
OIDC_ALLOWED_EMAIL_DOMAINS=example.com
OIDC_REQUIRE_VERIFIED_EMAIL=true
OIDC_ALLOW_PRIVATE_ENDPOINTS=false
OIDC_ALLOW_INSECURE_HTTP=false
REQUIRE_SEPARATE_APPROVER=true
COOKIE_SECURE=false
TRUST_PROXY=false
EXECUTION_MODE=disabled
DEPLOYMENT_EXECUTION_MODE=disabled
ALLOW_PRIVATE_AI_ENDPOINTS=false
LOG_LEVEL=info
